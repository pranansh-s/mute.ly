{
  "name": "mutely-extension",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && vite build --config vite.worker.config.ts",
    "clean": "rm -rf dist",
    "install-host": "node host/install.cjs",
    "uninstall-host": "node host/uninstall.cjs",
    "test:scheduler": "tsc && node --test test/aot-scheduler.test.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-static-copy": "^3.4.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@ricky0123/vad-web": "^0.0.30",
    "onnxruntime-web": "^1.24.3"
  }
}
