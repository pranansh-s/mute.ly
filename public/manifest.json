{
  "manifest_version": 3,
  "name": "Mute.ly",
  "version": "3.0.0",
  "minimum_chrome_version": "116",
  "description": "Free, private YouTube captions powered by local AI — no server, no API keys, no data ever leaves your browser",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "offscreen",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "chunks/*"
      ],
      "matches": [
        "https://youtube.com/*",
        "https://www.youtube.com/*"
      ]
    }
  ]
}